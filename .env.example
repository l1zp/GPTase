# ========================================
# GPTase Environment Configuration
# ========================================

# ----------------
# LLM Provider Keys
# ----------------
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# Custom/In-house Provider
CUSTOM_API_KEY=your_custom_api_key
CUSTOM_BASE_URL=https://your-api-endpoint.com

# ----------------
# MCP Server Keys
# ----------------
BRAVE_API_KEY=your_brave_api_key_here
TAVILY_API_KEY=your_tavily_api_key_here

# ----------------
# Framework Settings (Optional)
# ----------------
MAF_LLM_PROVIDER=openai
MAF_LLM_MODEL=gpt-4
MAF_LLM_TEMPERATURE=0.1
MAF_LLM_MAX_TOKENS=2000

# Memory Configuration
MAF_MEMORY_TYPE=local
MAF_MEMORY_MAX_HISTORY=1000
MAF_MEMORY_PERSISTENCE_FILE=memory_store.json

# Tool Configuration
MAF_TOOLS_TIMEOUT=30
MAF_TOOLS_MAX_RETRIES=3
MAF_TOOLS_SANDBOX_ENABLED=true

# Logging Configuration
MAF_LOG_LEVEL=INFO

# ----------------
# MinerU Cloud API
# ----------------
MINERU_TOKEN=your_mineru_token_here
